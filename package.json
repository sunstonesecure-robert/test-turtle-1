{
  "name": "agentic-turtles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "init": "tsx scripts/setup-repo.ts",
    "gate:plan": "tsx scripts/gates/plan-gate.ts",
    "gate:preflight": "tsx scripts/gates/build-preflight.ts",
    "gate:lifecycle": "tsx scripts/gates/lifecycle-gate.ts",
    "demo:propose-plan": "tsx scripts/demo/propose-plan.ts",
    "demo:agent-revise": "tsx scripts/demo/agent-revise.ts",
    "test": "vitest run",
    "test:bdd": "NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "npm run dev --workspace dashboard"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^22.10.0",
    "msw": "^2.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "zod": "^3.24.0"
  }
}
